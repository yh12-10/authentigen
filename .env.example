# =============================================================================
# AuthentiGen — Environment Variables
# Copy this file to `.env` and fill in real values for local development.
# =============================================================================

# ── Database (MySQL) ─────────────────────────────────────────────────────────
# For local Node + MySQL, point this at your own database.
# When running via `docker compose up`, this is supplied automatically — leave as-is.
DATABASE_URL=mysql://root:authgen@localhost:3306/authentigen

# ── Session signing ──────────────────────────────────────────────────────────
# Auto-generated and persisted to .env on first dev run if missing.
# In production: set this manually to a 32+ char random string.
JWT_SECRET=

# ── Stripe (leave blank to disable paid checkout — UI shows a friendly notice)
# Test keys: sk_test_... / whsec_... / price_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=

# Public origin used in Stripe success/cancel redirects.
APP_BASE_URL=http://localhost:3000

# ── Video pipeline ───────────────────────────────────────────────────────────
# Hard cap on input video duration; over-limit jobs auto-refund credits.
VIDEO_MAX_DURATION_SECONDS=30
# Sample every Nth frame; honours the "honest" sampled-frame UX promise.
VIDEO_FRAME_SAMPLE_EVERY=3

# ── Storage backend ──────────────────────────────────────────────────────────
# "local" (default) stores files under ./storage. Set "s3" to use S3 or any
# S3-compatible service (Cloudflare R2, MinIO, Backblaze B2).
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=                 # optional, for S3-compatible providers
S3_FORCE_PATH_STYLE=false    # set true for MinIO
S3_PUBLIC_URL=               # optional public/CDN base; otherwise presigned URLs are used
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Email (SMTP, optional) ───────────────────────────────────────────────────
# Leave SMTP_HOST/SMTP_FROM blank to disable email (falls back to console logs).
# Works with any SMTP provider, or Mailhog for local dev (docker --profile dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Address that receives owner/admin notifications.
OWNER_EMAIL=

# ── Rate limiting (applied to /api/trpc) ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
# Set when running behind a reverse proxy (e.g. "1" or "loopback").
TRUST_PROXY=

# ── Job processing ───────────────────────────────────────────────────────────
# Max image humanizations running at once (excess jobs queue).
MAX_CONCURRENT_IMAGE_JOBS=4
